# ============================================================
# LinkedIn Job Automator - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- LinkedIn Credentials ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Groq API (for AI post analysis) ---
GROQ_API_KEY=

# --- Email: Approval Notifications (sender) ---
# This account SENDS approval requests TO you
APPROVAL_SENDER_EMAIL=
APPROVAL_SENDER_PASSWORD=

# --- Email: Your approval inbox (where you reply "ok") ---
APPROVAL_RECEIVER_EMAIL=

# --- Email: Application sender (sends to recruiters) ---
# This account sends actual job applications
APPLICATION_SENDER_EMAIL=
APPLICATION_SENDER_PASSWORD=  # Gmail App Password

# --- Resume PDF path ---
RESUME_PDF_PATH=

# --- Scheduler interval (hours between LinkedIn scans) ---
SCAN_INTERVAL_HOURS=3

# --- How many LinkedIn feed posts to scroll through each run ---
MAX_POSTS_TO_SCAN=100

# --- Run browser in headless mode (no window pops up, required in VM cloud environment) ---
HEADLESS=True

